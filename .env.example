# ============================================================================
# RAMESHWAR AUTOTECH - Environment Variables Configuration
# ============================================================================
#
# COPY THIS FILE TO:
# - .env (local development - use SQLite)
# - .env.production (production - use Neon)
#
# NEVER commit passwords or DATABASE_URL to Git!
# Use environment secrets on your hosting platform.
#
# ============================================================================

# ======================== LOCAL DEVELOPMENT (.env) ========================

# Database
USE_NEON=false                          # Use SQLite locally
# DATABASE_URL not needed for SQLite - it uses backend/database/rameshwar_autotech.db

# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173      # Vite dev server

# Frontend
VITE_BASE_URL=http://localhost:5000    # Local backend URL

# Email (optional - for contact form notifications)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@rameshwarautotech.com

# JWT Secret (use a random string in production)
JWT_SECRET=dev-secret-key-change-in-production

# ======================== PRODUCTION (.env.production) ========================

# Database - NEON POSTGRES
USE_NEON=true                           # Use Neon Postgres
DATABASE_URL=postgresql://user:password@endpoint.neon.tech/dbname?sslmode=require

# Server
PORT=5000
NODE_ENV=production
CORS_ORIGIN=https://your-domain.com    # Your frontend domain

# Frontend
VITE_BASE_URL=https://api.your-domain.com    # Your backend API URL

# Email (Required for contact form)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password            # Use app-specific password
EMAIL_FROM=noreply@rameshwarautotech.com

# JWT Secret (Use a strong random secret!)
JWT_SECRET=generate-random-secret-use-command-below

# ======================== OPTIONAL - ADVANCED ========================

# Logging
LOG_LEVEL=info                           # debug, info, warn, error

# Rate Limiting
RATE_LIMIT_WINDOW=900000                # 15 minutes in ms
RATE_LIMIT_MAX_REQUESTS=100             # Max requests per window

# Session
SESSION_TIMEOUT=3600000                 # 1 hour in ms

# ======================== HOW TO GET NEON DATABASE_URL ========================
#
# 1. Go to https://neon.com and sign up
# 2. Create a new project
# 3. Go to "Connection string" in dashboard
# 4. Copy the full connection string including password
# 5. Format: postgresql://user:password@ep-your-endpoint.neon.tech/dbname?sslmode=require
#
# ⚠️  IMPORTANT: This password is sensitive! Never commit to Git.
#
# On Render.com / Railway.com / Vercel:
# - Go to Environment Variables
# - Paste DATABASE_URL there
# - It will NOT show in logs or Github
#
# ======================== HOW TO GENERATE JWT_SECRET ========================
#
# Run this command in terminal:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Copy the output and use as JWT_SECRET in production
#
# ======================== DEPLOYMENT CHECKLIST ========================
#
# Before deploying to production:
#
# ✅ Create Neon project and get DATABASE_URL
# ✅ Generate strong JWT_SECRET
# ✅ Set up email credentials (for contact form)
# ✅ Set VITE_BASE_URL to your backend domain
# ✅ Set CORS_ORIGIN to your frontend domain
# ✅ Test locally with USE_NEON=false first
# ✅ Test API endpoints before full deployment
# ✅ Set all env vars on hosting platform (Render, Vercel, etc)
# ✅ Monitor backend logs on first deployment
# ✅ Test contact form on production
# ✅ Test admin login on production
# ✅ Verify data appears in Neon dashboard
#
# ======================== TYPICAL HOSTING SETUP ========================
#
# BACKEND DEPLOYMENT (Render.com)
# 1. Connect GitHub repo
# 2. Environment Variables:
#    - USE_NEON=true
#    - DATABASE_URL=postgresql://...
#    - NODE_ENV=production
#    - JWT_SECRET=... (generated secret)
#    - EMAIL_USER=...
#    - EMAIL_PASS=...
#    - CORS_ORIGIN=https://your-frontend-domain.com
# 3. Deploy
# 4. Copy backend URL (e.g., https://api.your-domain.com)
#
# FRONTEND DEPLOYMENT (Vercel)
# 1. Connect GitHub repo
# 2. Environment Variables:
#    - VITE_BASE_URL=https://api.your-domain.com
# 3. Deploy
#
# ======================== TROUBLESHOOTING ========================
#
# Q: "Connection refused" error
# A: Check DATABASE_URL is correct, Neon project is running
#
# Q: "CORS error" when submitting contact form
# A: Update CORS_ORIGIN on backend to match frontend domain
#
# Q: Contact form works locally but not on production
# A: Check VITE_BASE_URL points to correct backend URL
#
# Q: Admin login not working
# A: Check JWT_SECRET is set on production server
#
# Q: Data not appearing in Neon
# A: Check USE_NEON=true on backend, DATABASE_URL is correct
#
